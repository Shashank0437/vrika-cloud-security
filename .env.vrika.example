# Copy to .env on the POC server (192.168.9.188) and fill secrets.
# cp .env.vrika.example .env
#
# Public URL: https://192.168.9.188/prowler/  (host nginx :443, NOT :9443)

PROWLER_UI_VERSION=stable
PROWLER_API_VERSION=stable
PROWLER_MCP_VERSION=stable

# Next.js basePath + Auth.js canonical URL
NEXT_PUBLIC_BASE_PATH=/prowler
NEXT_PUBLIC_VRIKA_EMBED_MODE=true
VRIKA_PDF_BRANDING=true
AUTH_URL=https://192.168.9.188/prowler

API_BASE_URL=http://api:8080/api/v1
UI_API_BASE_URL=https://192.168.9.188/prowler/api/v1
NEXT_PUBLIC_API_BASE_URL=https://192.168.9.188/prowler/api/v1
UI_API_DOCS_URL=https://192.168.9.188/prowler/api/v1/docs
NEXT_PUBLIC_API_DOCS_URL=https://192.168.9.188/prowler/api/v1/docs

PROWLER_MCP_SERVER_URL=http://mcp-server:8000/mcp
AUTH_TRUST_HOST=true

AUTH_SECRET=change-me-auth-secret
VRIKA_BRIDGE_SECRET=change-me-vrika-bridge-secret

# Platform LLM (OpenRouter) — used by Lighthouse AI in Vrika embed
VRIKA_LLM_API_KEY=
VRIKA_LLM_URL=https://openrouter.ai/api/v1
VRIKA_LLM_MODEL=openai/gpt-4.1-mini
VRIKA_LLM_PROVIDER=openrouter

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api,192.168.9.188
DJANGO_CORS_ALLOWED_ORIGINS=https://192.168.9.188,http://127.0.0.1:8090
DJANGO_SETTINGS_MODULE=config.django.production
DJANGO_PORT=8080

POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432
POSTGRES_ADMIN_USER=prowler_admin
POSTGRES_ADMIN_PASSWORD=change-me-postgres-admin
POSTGRES_USER=prowler
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=prowler_db

VALKEY_SCHEME=redis
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_DB=0

NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j
